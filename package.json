{
  "name": "afm-js-monorepo",
  "version": "0.0.3",
  "private": true,
  "description": "Apple Foundation Models for Node.js / TypeScript — OpenAI-compatible HTTP server + CLI",
  "license": "MIT",
  "author": "Tariq West",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run packages/afm-js/test/e2e",
    "typecheck": "tsc --build",
    "clean": "tsc --build --clean && rm -rf packages/*/dist",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "release:brew:generate": "node scripts/generate-homebrew-formula.js",
    "release:brew:publish": "node scripts/publish-to-tap.js",
    "release:prepare": "pnpm run build && pnpm run test && pnpm run release:brew:generate",
    "release": "node scripts/release.js",
    "ci": "pnpm run build && pnpm run test && pnpm run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.10",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "vite": ">=6.4.2",
    "esbuild": ">=0.28.1"
  },
  "packageManager": "pnpm@9.15.0"
}
